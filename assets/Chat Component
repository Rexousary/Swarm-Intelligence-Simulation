# ─────────────────────────────────────────────────────────────────────
#  CHAT ENGINE
# ─────────────────────────────────────────────────────────────────────

class ChatEngine:
    """
    Full Discord-style chat backend.
    Manages channels, messages, AI responses, and strategy relay.
    """
    def __init__(self):
        self.messages:   Dict[Channel, List[Message]] = defaultdict(list)
        self.dm_threads: Dict[str, List[Message]] = defaultdict(list)  # "A→B": [msgs]
        self.msg_counter = 0
        self.pinned_ids: Set = set()
        self.players: List[str] = []
        self.online_agents: List[str] = []
        self.strategy_log: List[str] = []
        self.command_callbacks: Dict[str, Callable] = {}

        # Rate limiting (messages per player per tick)
        self.rate_limit: Dict[str, int] = defaultdict(int)

        # System welcome messages
        self._post_system(Channel.GLOBAL, "═══ Metahuman Swarm Battle Chat — Online ═══")
        self._post_system(Channel.TEAM_ALPHA, "Team ALPHA channel secured. 🔶")
        self._post_system(Channel.TEAM_OMEGA, "Team OMEGA channel secured. 🔷")
        self._post_system(Channel.STRATEGY_ROOM, "Strategy Room open. Plans made here stay here.")
        self._post_system(Channel.ALERTS, "Alert channel active. Critical events broadcast here.")

    # ── Internal helpers ───────────────────────────────────────────
    def _ts(self) -> str:
        return datetime.now().strftime("%H:%M:%S")

    def _next_id(self) -> int:
        self.msg_counter += 1
        return self.msg_counter

    def _extract_mentions(self, content: str) -> List[str]:
        return [w[1:] for w in content.split() if w.startswith("@")]

    def _post(self, channel: Channel, sender: str, content: str,
              msg_type: MessageType = MessageType.CHAT,
              reply_to: Optional[int] = None) -> Message:
        msg = Message(
            msg_id   = self._next_id(),
            timestamp= self._ts(),
            channel  = channel,
            sender   = sender,
            msg_type = msg_type,
            content  = content,
            mentions = self._extract_mentions(content),
            reply_to = reply_to,
        )
        self.messages[channel].append(msg)
        return msg

    def _post_system(self, channel: Channel, content: str) -> Message:
        return self._post(channel, "SYSTEM", content, MessageType.SYSTEM)

    def _ai_response(self, channel: Channel, agent_name: str,
                     content: str, reply_to: Optional[int] = None) -> Message:
        return self._post(channel, agent_name, content, MessageType.AI_RESPONSE, reply_to)

    # ── Player registration ────────────────────────────────────────
    def register_player(self, name: str, team: str):
        self.players.append(name)
        self._post_system(Channel.GLOBAL, f"⚡ {name} joined Team {team}")
        print(f"  ✅ Player '{name}' registered on Team {team}")

    def register_agent(self, agent_name: str):
        self.online_agents.append(agent_name)
        p = AGENT_PERSONALITIES.get(agent_name, {})
        emoji = p.get("emoji", "🤖")
        team  = p.get("team", "?")
        greeting = random.choice(p.get("greetings", ["Online and ready."]))
        ch = Channel.TEAM_ALPHA if team == "ALPHA" else Channel.TEAM_OMEGA
        self._ai_response(ch, f"{emoji}{agent_name}", greeting)

    # ── Player sends a message ─────────────────────────────────────
    def send_message(self, player: str, channel: Channel, content: str,
                     reply_to: Optional[int] = None) -> Message:
        msg = self._post(channel, player, content, MessageType.CHAT, reply_to)

        # Check for slash commands
        if content.startswith("/"):
            self._handle_command(player, channel, content, msg.msg_id)
        else:
            # Check if message mentions an agent — trigger AI reply
            for agent in self.online_agents:
                if agent.lower() in content.lower() or f"@{agent}" in content:
                    self._trigger_agent_reply(agent, channel, content, msg.msg_id)
                    break

        return msg

    def send_dm(self, sender: str, recipient: str, content: str) -> Message:
        key = f"{sender}→{recipient}"
        msg = Message(
            msg_id   = self._next_id(),
            timestamp= self._ts(),
            channel  = Channel.GLOBAL,
            sender   = sender,
            msg_type = MessageType.CHAT,
            content  = f"[DM to {recipient}] {content}",
            mentions = [recipient],
        )
        self.dm_threads[key].append(msg)
        # If recipient is an agent, auto-reply
        if recipient in self.online_agents:
            p = AGENT_PERSONALITIES.get(recipient, {})
            emoji = p.get("emoji", "🤖")
            reply = self._generate_agent_reply(recipient, content)
            reply_msg = Message(
                msg_id   = self._next_id(),
                timestamp= self._ts(),
                channel  = Channel.GLOBAL,
                sender   = f"{emoji}{recipient}",
                msg_type = MessageType.AI_RESPONSE,
                content  = f"[DM to {sender}] {reply}",
            )
            self.dm_threads[f"{recipient}→{sender}"].append(reply_msg)
            print(f"  💬 DM [{recipient} → {sender}]: {reply}")
        return msg

    # ── Command handler ────────────────────────────────────────────
    def _handle_command(self, player: str, channel: Channel,
                        content: str, msg_id: int):
        parts = content.split()
        cmd   = parts[0].lower()
        args  = parts[1:]

        if cmd == "/help":
            help_text = "Available commands: " + " | ".join(SLASH_COMMANDS.keys())
            self._post_system(channel, help_text)

        elif cmd == "/strategy":
            plan = " ".join(args) if args else "No plan specified"
            self.strategy_log.append(f"[{self._ts()}] {player}: {plan}")
            self._post(channel, f"📋 {player}", plan, MessageType.STRATEGY)
            # Agents in team acknowledge
            team = self._player_team(player)
            for agent in self._team_agents(team):
                p = AGENT_PERSONALITIES.get(agent, {})
                ack = random.choice(p.get("strategy_lines", ["Understood."]))
                self._ai_response(channel, f"{p.get('emoji','🤖')}{agent}",
                                  ack, reply_to=msg_id)

        elif cmd == "/regroup":
            self._post(channel, player, "🔗 REGROUP ORDER ISSUED", MessageType.COMMAND)
            team = self._player_team(player)
            for agent in self._team_agents(team):
                p = AGENT_PERSONALITIES.get(agent, {})
                line = random.choice(p.get("regroup_lines", ["Regrouping."]))
                self._ai_response(channel, f"{p.get('emoji','🤖')}{agent}", line, reply_to=msg_id)
            # Relay to navigation (would hook into SwarmNavigator)
            self._relay_order("REGROUP", team=team)

        elif cmd == "/attack":
            target = args[0] if args else "Unknown"
            agent  = args[1] if len(args) > 1 else "all"
            self._post(channel, player, f"⚔️ ATTACK ORDER → [{agent}] target [{target}]",
                       MessageType.COMMAND)
            self._relay_order("ATTACK", agent=agent, target=target)
            # Agent acknowledge
            for ag in self._team_agents(self._player_team(player)):
                if agent == "all" or agent.lower() in ag.lower():
                    p = AGENT_PERSONALITIES.get(ag, {})
                    line = random.choice(p.get("attack_lines", ["Attacking!"]))
                    self._ai_response(channel, f"{p.get('emoji','🤖')}{ag}",
                                      line, reply_to=msg_id)

        elif cmd == "/defend":
            location = args[0] if args else "Parliament_Hall"
            self._post(channel, player, f"🛡️ DEFEND ORDER → [{location}]", MessageType.COMMAND)
            self._relay_order("DEFEND", target=location)
            for ag in self._team_agents(self._player_team(player)):
                p = AGENT_PERSONALITIES.get(ag, {})
                line = random.choice(p.get("defend_lines", ["Defending."]))
                self._ai_response(channel, f"{p.get('emoji','🤖')}{ag}", line, reply_to=msg_id)

        elif cmd == "/roam":
            agent = args[0] if args else "all"
            self._post(channel, player, f"🚶 ROAM ORDER → [{agent}]", MessageType.COMMAND)
            self._relay_order("ROAM", agent=agent)

        elif cmd == "/status":
            target = args[0] if args else "all"
            self._post_system(channel, f"📊 Status report requested for: {target}")

        elif cmd == "/ping":
            target = args[0] if args else "Unknown"
            self._post(channel, player, f"🔔 @{target} — PING!", MessageType.COMMAND)

        elif cmd == "/pin":
            if args and args[0].isdigit():
                self.pinned_ids.add(int(args[0]))
                self._post_system(channel, f"📌 Message #{args[0]} pinned.")

        elif cmd == "/team":
            team_msg = " ".join(args)
            team = self._player_team(player)
            team_ch = Channel.TEAM_ALPHA if team == "ALPHA" else Channel.TEAM_OMEGA
            self._post(team_ch, player, team_msg, MessageType.BROADCAST)

        elif cmd == "/ask":
            if len(args) >= 2:
                agent_name = args[0]
                question   = " ".join(args[1:])
                if agent_name in self.online_agents:
                    reply = self._generate_agent_reply(agent_name, question)
                    p = AGENT_PERSONALITIES.get(agent_name, {})
                    self._ai_response(channel,
                                      f"{p.get('emoji','🤖')}{agent_name}",
                                      reply, reply_to=msg_id)
                else:
                    self._post_system(channel, f"Agent '{agent_name}' not found.")

        elif cmd == "/alert":
            alert_msg = " ".join(args)
            self._post(Channel.ALERTS, player, alert_msg, MessageType.ALERT)
            # Echo to all channels
            for ch in [Channel.TEAM_ALPHA, Channel.TEAM_OMEGA]:
                self._post_system(ch, f"🚨 ALERT from {player}: {alert_msg}")

        else:
            self._post_system(channel, f"Unknown command: {cmd}. Type /help for commands.")

    # ── Agent AI reply generation ──────────────────────────────────
    def _generate_agent_reply(self, agent_name: str, trigger_text: str) -> str:
        p = AGENT_PERSONALITIES.get(agent_name, {})
        text_lower = trigger_text.lower()

        if any(w in text_lower for w in ["attack", "fight", "charge", "go"]):
            return random.choice(p.get("attack_lines", ["Engaging!"]))
        elif any(w in text_lower for w in ["defend", "hold", "protect", "guard"]):
            return random.choice(p.get("defend_lines", ["Defending!"]))
        elif any(w in text_lower for w in ["strategy", "plan", "think", "what should"]):
            return random.choice(p.get("strategy_lines", ["Good question."]))
        elif any(w in text_lower for w in ["lost", "where", "help", "missing"]):
            return random.choice(p.get("lost_lines", ["Working on it."]))
        elif any(w in text_lower for w in ["regroup", "come back", "retreat"]):
            return random.choice(p.get("regroup_lines", ["On my way."]))
        elif any(w in text_lower for w in ["fire", "danger", "enemy"]):
            return p.get("react_to_fire", "Understood, staying alert.")
        else:
            # Generic greeting/acknowledgement
            return random.choice(p.get("greetings", ["Ready."]))

    def _trigger_agent_reply(self, agent_name: str, channel: Channel,
                             content: str, reply_to: int):
        p     = AGENT_PERSONALITIES.get(agent_name, {})
        emoji = p.get("emoji", "🤖")
        reply = self._generate_agent_reply(agent_name, content)
        self._ai_response(channel, f"{emoji}{agent_name}", reply, reply_to=reply_to)

    # ── Utility ───────────────────────────────────────────────────
    def _player_team(self, player: str) -> str:
        # Simple: first 4 players are ALPHA, next are OMEGA
        # In real integration, look up player team from battle engine
        return "ALPHA"

    def _team_agents(self, team: str) -> List[str]:
        return [a for a in self.online_agents
                if AGENT_PERSONALITIES.get(a, {}).get("team") == team]

    def _relay_order(self, order: str, **kwargs):
        """Relay chat command to navigation/battle engine (hook point)."""
        self.strategy_log.append(f"[RELAY] {order} | {kwargs}")

    def post_combat_event(self, event: str):
        """Battle engine posts events to Combat Log channel."""
        self._post(Channel.COMBAT_LOG, "ENGINE", event, MessageType.ALERT)

    def post_alert(self, message: str):
        self._post(Channel.ALERTS, "ENGINE", message, MessageType.ALERT)
        self._post_system(Channel.TEAM_ALPHA, f"🚨 {message}")
        self._post_system(Channel.TEAM_OMEGA, f"🚨 {message}")

    # ── Display ───────────────────────────────────────────────────
    def render_channel(self, channel: Channel, last_n: int = 20):
        msgs  = self.messages[channel][-last_n:]
        width = 100
        print(f"\n{'═'*width}")
        print(f"  {channel.value}  ({len(self.messages[channel])} messages total)")
        print(f"{'═'*width}")
        if not msgs:
            print("  (no messages)")
        for m in msgs:
            line = m.render()
            if m.msg_id in self.pinned_ids:
                line += " 📌"
            print(line)
        print(f"{'═'*width}")

    def render_dm_thread(self, player_a: str, player_b: str):
        key1 = f"{player_a}→{player_b}"
        key2 = f"{player_b}→{player_a}"
        msgs = sorted(self.dm_threads.get(key1, []) +
                      self.dm_threads.get(key2, []),
                      key=lambda m: m.msg_id)
        print(f"\n  💬 DM Thread: {player_a} ↔ {player_b}")
        print(f"  {'─'*60}")
        for m in msgs:
            print(m.render())

    def render_pinned(self, channel: Channel):
        print(f"\n  📌 PINNED in {channel.value}:")
        for m in self.messages[channel]:
            if m.msg_id in self.pinned_ids:
                print(m.render())

    def render_strategy_log(self):
        print(f"\n  📋 STRATEGY LOG ({len(self.strategy_log)} entries):")
        print(f"  {'─'*70}")
        for entry in self.strategy_log:
            print(f"  {entry}")

    def channel_summary(self) -> str:
        lines = ["\n  📡 CHANNEL SUMMARY:"]
        for ch in Channel:
            count = len(self.messages[ch])
            lines.append(f"    {ch.value:<30} {count:4d} messages")
        return "\n".join(lines)


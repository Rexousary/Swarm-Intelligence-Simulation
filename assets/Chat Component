import time
import random
from datetime import datetime
from enum import Enum
from dataclasses import dataclass, field
from typing import List, Dict, Optional, Callable
from collections import defaultdict, deque

# ─────────────────────────────────────────────────────────────────────
#  ENUMS
# ─────────────────────────────────────────────────────────────────────

class Channel(Enum):
    GLOBAL        = "🌐 Global"
    TEAM_ALPHA    = "🔶 Team ALPHA"
    TEAM_OMEGA    = "🔷 Team OMEGA"
    STRATEGY_ROOM = "📋 Strategy Room"
    ALERTS        = "🚨 Alerts"
    COMBAT_LOG    = "⚔️  Combat Log"

class MessageType(Enum):
    CHAT        = "CHAT"
    SYSTEM      = "SYSTEM"
    COMMAND     = "COMMAND"
    AI_RESPONSE = "AI_RESPONSE"
    ALERT       = "ALERT"
    STRATEGY    = "STRATEGY"
    BROADCAST   = "BROADCAST"

class AgentElement(Enum):
    FIRE    = "Fire"
    WATER   = "Water"
    THUNDER = "Thunder"
    EARTH   = "Earth"
    GRASS   = "Grass"
    SAND    = "Sand"
    FLYING  = "Flying"
    DARK    = "Dark"

# ─────────────────────────────────────────────────────────────────────
#  MESSAGE DATACLASS
# ─────────────────────────────────────────────────────────────────────

@dataclass
class Message:
    msg_id:    int
    timestamp: str
    channel:   Channel
    sender:    str
    msg_type:  MessageType
    content:   str
    mentions:  List[str] = field(default_factory=list)
    reply_to:  Optional[int] = None
    pinned:    bool = False

    def render(self) -> str:
        pin_str  = " 📌" if self.pinned else ""
        type_tag = {
            MessageType.CHAT:        "      ",
            MessageType.SYSTEM:      "[SYS] ",
            MessageType.COMMAND:     "[CMD] ",
            MessageType.AI_RESPONSE: "[AI]  ",
            MessageType.ALERT:       "[❗]  ",
            MessageType.STRATEGY:    "[📋]  ",
            MessageType.BROADCAST:   "[📢]  ",
        }.get(self.msg_type, "      ")
        reply_str = f" ↩️ #{self.reply_to}" if self.reply_to else ""
        return (f"  [{self.timestamp}] {type_tag}{self.sender:<18} "
                f"{self.content}{reply_str}{pin_str}")

